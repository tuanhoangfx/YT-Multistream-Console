{
  "name": "yt-multistream-console",
  "version": "0.1.26",
  "private": true,
  "description": "Desktop console for multi-channel YouTube livestream from local or Google Drive source.",
  "author": "YT Multistream Console",
  "main": "electron/main.cjs",
  "repository": {
    "type": "git",
    "url": "https://github.com/tuanhoangfx/YT-Multistream-Console.git"
  },
  "scripts": {
    "dev": "concurrently -k \"vite --host 127.0.0.1 --port 5174\" \"wait-on tcp:5174 && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5174 electron .\"",
    "build": "tsc --noEmit && vite build",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "test": "cross-env SKIP_DRIVE_CHECK=1 pnpm test:smoke",
    "test:unit": "vitest run",
    "test:smoke": "node scripts/smoke-test.cjs",
    "test:smoke:ci": "cross-env SKIP_DRIVE_CHECK=1 pnpm test:smoke",
    "test:smoke:full": "pnpm test:smoke",
    "test:live": "node scripts/live-test.cjs",
    "audit:cleanup": "node scripts/audit-cleanup.mjs",
    "sync:bump": "node scripts/bump-patch-version.mjs",
    "sync:releaselog": "node scripts/sync-release-log.mjs",
    "check:version-sync": "node scripts/check-version-sync.mjs",
    "check:releaselog": "node scripts/sync-release-log.mjs --check",
    "sync:meta": "node scripts/sync-metadata-version.mjs",
    "sync:all": "pnpm release:stamp",
    "finalize:change": "pnpm release:stamp",
    "release:stamp": "pnpm sync:bump && pnpm sync:meta && pnpm sync:releaselog && pnpm check:version-sync",
    "release:code-only-stamp": "node scripts/release-stamp-if-code-change.mjs",
    "release:auto": "pnpm release:code-only-stamp",
    "release:tag-local": "node scripts/tag-local-release.mjs",
    "rollback:list": "git tag --list \"v*\" --sort=-v:refname",
    "rollback:restore": "node scripts/rollback-to-tag.mjs",
    "hooks:install": "node scripts/install-git-hooks.mjs",
    "assets:icon": "node scripts/render-brand-icon.cjs",
    "pack": "pnpm assets:icon && corepack pnpm build && electron-builder --dir",
    "dist": "pnpm assets:icon && corepack pnpm build && electron-builder --win nsis --publish never",
    "release": "pnpm assets:icon && corepack pnpm build && electron-builder --win nsis --publish always",
    "preview": "vite preview --host 127.0.0.1 --port 5174",
    "start": "electron .",
    "postinstall": "pnpm hooks:install"
  },
  "dependencies": {
    "@ffmpeg-installer/ffmpeg": "^1.1.0",
    "@ffmpeg-installer/win32-x64": "4.1.0",
    "@vitejs/plugin-react": "^5.1.1",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "debug": "^4.4.0",
    "electron-updater": "^6.8.3",
    "lucide-react": "^0.561.0",
    "ms": "^2.1.3",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "vite": "^7.2.7",
    "wait-on": "^9.0.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "electron": "^39.2.7",
    "electron-builder": "^26.8.1",
    "eslint": "^10.2.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "png-to-ico": "^3.0.1",
    "prettier": "^3.8.3",
    "sharp": "^0.34.5",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.59.1",
    "vitest": "^4.1.5",
    "jsdom": "^26.1.0"
  },
  "build": {
    "appId": "com.yt.multistream-console",
    "productName": "YT Multistream Console",
    "artifactName": "YT-Multistream-Console-Setup-${version}.${ext}",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**",
      "electron/**",
      "build/icons/**",
      "package.json",
      "RELEASE.md"
    ],
    "extraResources": [
      {
        "from": "node_modules/@ffmpeg-installer/win32-x64/ffmpeg.exe",
        "to": "bin/ffmpeg.exe"
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "build/icons/app.ico"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "publish": [
      {
        "provider": "github",
        "owner": "tuanhoangfx",
        "repo": "YT-Multistream-Console",
        "releaseType": "release"
      }
    ]
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "esbuild",
      "sharp"
    ]
  }
}
